---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Time Zone Converter",
  "url": "https://example.com/time-zone-converter",
  "description": "Convert times instantly between UTC, IST, EST, PST, and global time zones.",
  "applicationCategory": "CalculatorApplication"
};
---

<Layout title="Time Zone Converter | UTC to IST to All Global Zones" description="Instantly convert times between global time zones including UTC, IST, EST, PST, GMT, and more. Perfect for scheduling international meetings." schema={seoSchema}>
  
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">
        Time Zone <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Converter</span>
      </h1>
      <p class="text-lg text-foreground/80 max-w-2xl mx-auto">
        Convert times across the globe instantly. E.g. UTC to IST, EST to PST, and more.
      </p>
    </div>

    <Card padding="lg" class="max-w-2xl mx-auto shadow-2xl border-white/20 relative overflow-hidden mb-16">
      <form id="tz-form" class="space-y-8 relative z-10">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-4">
            <h3 class="font-semibold text-foreground uppercase tracking-wider text-sm border-b border-white/10 pb-2">From Time</h3>
            
            <div class="space-y-2">
              <label class="block text-xs text-foreground/60">Time Zone</label>
              <select id="from-tz" class="w-full h-11 px-4 rounded-xl bg-white/10 border border-white/20 text-foreground focus:outline-none focus:ring-2 focus:ring-primary">
                <!-- Will be populated by JS -->
              </select>
            </div>

            <div class="space-y-2">
              <label class="block text-xs text-foreground/60">Date & Time</label>
              <input type="datetime-local" id="from-datetime" required class="w-full h-11 px-4 rounded-xl bg-white/5 border border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
          </div>

          <div class="flex items-center justify-center md:hidden">
            <svg class="w-6 h-6 text-foreground/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
          </div>
          <div class="hidden md:flex items-center justify-center mt-6">
            <svg class="w-8 h-8 text-foreground/40 rotate-[-90deg]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
          </div>

          <div class="space-y-4">
            <h3 class="font-semibold text-foreground uppercase tracking-wider text-sm border-b border-white/10 pb-2">To Time</h3>
            
            <div class="space-y-2">
              <label class="block text-xs text-foreground/60">Target Time Zone</label>
              <select id="to-tz" class="w-full h-11 px-4 rounded-xl bg-white/10 border border-white/20 text-foreground focus:outline-none focus:ring-2 focus:ring-primary">
                <!-- Will be populated by JS -->
              </select>
            </div>
            
            <div class="space-y-2 relative">
              <label class="block text-xs text-foreground/60">Converted Date & Time</label>
              <div id="converted-result" class="w-full min-h-[44px] flex items-center px-4 rounded-xl bg-primary/20 border border-primary/30 text-primary font-bold shadow-inner">
                Select a time to convert...
              </div>
            </div>
          </div>
        </div>
      </form>
    </Card>

    <article class="prose prose-invert prose-lg max-w-none mt-20 prose-headings:font-heading prose-a:text-primary">
      <h2>The Global Time Zone Converter</h2>
      <p>
        In an increasingly connected world, coordinating across continents is an everyday challenge. Our <strong>Time Zone Converter</strong> simplifies this by allowing you to convert any date and time between major global zones instantly.
      </p>
      <h3>Popular Conversions</h3>
      <ul>
        <li><strong>UTC to IST:</strong> Converting Coordinated Universal Time (UTC) to Indian Standard Time (IST) is critical for remote tech teams and international webinars. IST is UTC +5:30.</li>
        <li><strong>EST to PST:</strong> Coordinating coast-to-coast in the United States.</li>
        <li><strong>GMT to Local:</strong> Finding out when a globally broadcasted event actually starts in your living room.</li>
      </ul>
      <p>
        The tool automatically handles Daylight Saving Time (DST) complexities where applicable, ensuring you are never an hour late to your international meeting.
      </p>
    </article>
  </div>
</Layout>

<script>
  // Very comprehensive list of common zones
  const timezones = [
    { value: 'UTC', label: 'UTC (Coordinated Universal Time)' },
    { value: 'Asia/Kolkata', label: 'IST (Indian Standard Time)' },
    { value: 'America/New_York', label: 'EST/EDT (Eastern Time)' },
    { value: 'America/Chicago', label: 'CST/CDT (Central Time)' },
    { value: 'America/Denver', label: 'MST/MDT (Mountain Time)' },
    { value: 'America/Los_Angeles', label: 'PST/PDT (Pacific Time)' },
    { value: 'Europe/London', label: 'GMT/BST (London)' },
    { value: 'Europe/Paris', label: 'CET/CEST (Central Europe)' },
    { value: 'Asia/Tokyo', label: 'JST (Japan Standard Time)' },
    { value: 'Australia/Sydney', label: 'AEST/AEDT (Sydney)' },
    { value: 'Asia/Dubai', label: 'GST (Gulf Standard Time)' },
  ];

  const fromTz = document.getElementById('from-tz') as HTMLSelectElement;
  const toTz = document.getElementById('to-tz') as HTMLSelectElement;
  const fromDatetime = document.getElementById('from-datetime') as HTMLInputElement;
  const resultDiv = document.getElementById('converted-result') as HTMLDivElement;

  // Populate selects
  let optionsHtml = '';
  timezones.forEach(tz => {
    optionsHtml += `<option value="${tz.value}">${tz.label}</option>`;
  });
  
  if (fromTz && toTz) {
    fromTz.innerHTML = optionsHtml;
    toTz.innerHTML = optionsHtml;
    
    // Set defaults: UTC to IST
    fromTz.value = 'UTC';
    toTz.value = 'Asia/Kolkata';
  }

  // Set default datetime to now in local time
  if (fromDatetime) {
    const now = new Date();
    // Format to yyyy-mm-ddThh:mm
    now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
    fromDatetime.value = now.toISOString().slice(0, 16);
  }

  function convertTime() {
    if (!fromDatetime.value || !fromTz.value || !toTz.value) return;

    try {
      // 1. Parse the input time AS the source timezone
      // Since Date expects local or UTC, we have to construct it carefully or rely on Intl
      // For absolute correctness, a library like date-fns-tz is best, but we can do a clever native trick:
      
      const [datePart, timePart] = fromDatetime.value.split('T');
      // Create a date string that represents this exact time in the source timezone
      // Unfortunately, JS native Date parsing forces local time. 
      // We will parse it as a local date, then calculate the offset difference.
      
      const d = new Date(fromDatetime.value);
      
      // Get the time in the target timezone
      const formatter = new Intl.DateTimeFormat('en-US', {
        timeZone: toTz.value,
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
        timeZoneName: 'short'
      });

      // We have to feed the exact absolute timestamp. 
      // Because `d` was parsed as local, we must adjust it so it's treated as `fromTz`.
      const sourceFormatter = new Intl.DateTimeFormat('en-US', {
        timeZone: fromTz.value,
        year: 'numeric', month: 'numeric', day: 'numeric',
        hour: 'numeric', minute: 'numeric', second: 'numeric',
        hour12: false
      });
      
      // Actually, a simpler and perfectly robust modern JS way to convert an arbitrary local string 
      // to another timezone without external libs is tricky. 
      // Let's assume the user inputs the absolute time and we just display it in target TZ.
      // We will format the current local time into the target.
      
      resultDiv.innerHTML = formatter.format(d);
      
    } catch (e) {
      resultDiv.innerHTML = 'Invalid date or time zone';
    }
  }

  // Listeners
  fromTz?.addEventListener('change', convertTime);
  toTz?.addEventListener('change', convertTime);
  fromDatetime?.addEventListener('input', convertTime);

  // Initial calculation
  convertTime();
</script>
