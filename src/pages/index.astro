---
import Layout from '../layouts/Layout.astro';
import CalculatorForm from '../components/CalculatorForm.astro';
import ResultCard from '../components/ResultCard.astro';
import Card from '../components/Card.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Exact Age Calculator",
  "url": "https://example.com/",
  "description": "Calculate your exact age in years, months, weeks, days, hours, minutes, and seconds.",
  "applicationCategory": "CalculatorApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an Age Calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An Age Calculator is an online tool that helps you determine your exact age in years, months, and days from your date of birth to the current date or a specific target date."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate my exact age?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Simply enter your date of birth into the calculator above. The tool automatically computes the time elapsed from that date to today, accounting for leap years and varying month lengths, to give you your exact age."
      }
    },
    {
      "@type": "Question",
      "name": "How does a leap year affect my age calculation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our algorithm precisely calculates the number of days in each month and year, including February 29th during leap years. This ensures that the total number of days lived is 100% accurate."
      }
    },
    {
      "@type": "Question",
      "name": "Can I calculate my age at a future or past date?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! By default, the calculator uses today's date. However, you can change the 'Target Date' field to any date in the past or future to find out how old you were, or will be, on that specific day."
      }
    }
  ]
};
---

<Layout 
  title="Exact Age Calculator | Calculate Age in Days, Hours & Seconds" 
  description="Use our highly accurate age calculator to find your exact age in years, months, weeks, days, hours, minutes, and seconds. Free online chronological age tool."
  schema={seoSchema}
>
  <div class="container mx-auto px-4 py-12 md:py-20 lg:py-24">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-6xl font-heading font-bold mb-6 tracking-tight text-foreground drop-shadow-sm">
        Exact Age <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary drop-shadow-sm">Calculator</span>
      </h1>
      <p class="text-lg md:text-xl text-foreground/80 max-w-2xl mx-auto font-medium">
        Discover exactly how old you are right down to the second.
      </p>
    </div>

