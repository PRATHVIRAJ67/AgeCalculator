---
import Layout from '../layouts/Layout.astro';
import CalculatorForm from '../components/CalculatorForm.astro';
import ResultCard from '../components/ResultCard.astro';
import Card from '../components/Card.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Exact Age Calculator",
  "url": "https://dateagecalculator.com/",
  "description": "Calculate your exact age in years, months, weeks, days, hours, minutes, and seconds.",
  "applicationCategory": "CalculatorApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0"
  }
};

const faqs = [
  {
    q: "What is the Date Age Calculator website?",
    a: "Date Age Calculator is an online suite of highly precise time and age calculation tools designed to give you your exact age down to the millisecond, along with unique chronological insights."
  },
  {
    q: "Are all the calculators on this website completely free to use?",
    a: "Yes, every single tool on our platform, from the exact age calculator to the planetary and pet age calculators, is 100% free to use with no hidden paywalls or subscription fees."
  },
  {
    q: "How accurate are the time and age calculations provided here?",
    a: "Our custom algorithms handle complex calendar math, dynamically accounting for leap years, varying month lengths, and exact time zones to ensure flawless accuracy down to the second."
  },
  {
    q: "Can I use these calculators on my mobile device or tablet?",
    a: "Absolutely. Our website is built with a highly responsive, modern design, meaning it works perfectly and looks beautiful on any smartphone, tablet, or desktop web browser."
  },
  {
    q: "Is my personal date of birth data stored or saved on your servers?",
    a: "No, we strictly prioritize your digital privacy. All age calculations are performed instantly in your browser. We never store, save, or transmit your date of birth or personal data to any servers."
  },
  {
    q: "Which types of calculators are available on this platform?",
    a: "We offer over 15 unique tools, including precise date difference calculators, time zone converters, live birthday countdowns, zodiac finders, and even fun calculators to find your age on Mars or in dog years."
  },
  {
    q: "Why should I choose this website over other age calculators?",
    a: "We offer a stunning, ad-free interface with unmatched precision, real-time live age counters, and a massive variety of specialized chronological tools that you simply won't find anywhere else."
  },
  {
    q: "Can I easily share my calculation results with friends or family?",
    a: "Yes! Our fun chronological statistics and unique life insights, like exactly how many total seconds you've been alive, are perfect for sharing on social media or comparing with friends."
  },
  {
    q: "Do these calculators work for international users across the globe?",
    a: "Yes, our tools are universally applicable. Our Time Zone Converter and precise date algorithms support global time formats and timezone adjustments flawlessly for users anywhere in the world."
  },
  {
    q: "Are the age and date calculations processed instantly?",
    a: "Yes, our lightweight platform executes all calendar mathematics instantly the moment you select your dates, providing real-time, lightning-fast results without any annoying page reloads."
  },
  {
    q: "How does the system handle complex leap year calculations?",
    a: "Our backend algorithms automatically detect leap years (years divisible by 4, except century years not divisible by 400) and precisely add the crucial 29th of February to your total lifetime day count."
  },
  {
    q: "Do I need to create an account or log in to use the tools?",
    a: "No account creation or registration is required. You can instantly access all of our premium calculators and features the moment you land on our homepage, completely anonymously."
  },
  {
    q: "Which web browsers are supported by this platform?",
    a: "Our website is heavily optimized for all modern web browsers, including Google Chrome, Apple Safari, Mozilla Firefox, and Microsoft Edge, across all operating systems."
  },
  {
    q: "How secure is the connection when I input my dates?",
    a: "We force an encrypted HTTPS connection across the entire site, ensuring that your connection is secure and your browser interactions are completely private and protected."
  },
  {
    q: "Will you be adding more calculators in the future?",
    a: "Yes! We are constantly expanding our suite of tools. Check back frequently for exciting new additions like advanced payroll calculators and highly specialized astrological converters."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<Layout 
  title="Exact Age Calculator | Calculate Age in Days, Hours & Seconds" 
  description="Use our highly accurate age calculator to find your exact age in years, months, weeks, days, hours, minutes, and seconds. Free online chronological age tool."
  schema={seoSchema}
>
  <div class="container mx-auto px-4 py-12 md:py-20 lg:py-24">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-6xl font-heading font-bold mb-6 tracking-tight text-foreground drop-shadow-sm">
        Exact Age <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary drop-shadow-sm">Calculator</span>
      </h1>
      <p class="text-lg md:text-xl text-foreground/80 max-w-2xl mx-auto font-medium">
        Discover exactly how old you are right down to the second.
      </p>
    </div>

    <div class="max-w-3xl mx-auto space-y-8">
      <Card padding="lg" class="shadow-2xl border-white/20 relative overflow-hidden group">
        <!-- Subtle inner glow -->
        <div class="absolute inset-0 bg-gradient-to-b from-white/5 to-transparent pointer-events-none"></div>
        <div class="relative z-10">
          <CalculatorForm />
        </div>
      </Card>

      <ResultCard />
    </div>
  </div>

  <div class="container mx-auto px-4 py-8 max-w-5xl">
    
    <!-- Small Professional SEO Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
      <Card padding="md" class="bg-white/5 border-white/10 shadow-lg text-center hover:-translate-y-1 transition-transform">
        <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center mx-auto mb-4 text-primary">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="font-bold text-foreground mb-2">100% Precise Accuracy</h3>
        <p class="text-sm text-foreground/60 leading-relaxed">Our advanced algorithm handles complex calendar math, accounting for varying month lengths and leap years to calculate your exact chronological age.</p>
      </Card>

      <Card padding="md" class="bg-white/5 border-white/10 shadow-lg text-center hover:-translate-y-1 transition-transform">
        <div class="w-12 h-12 rounded-full bg-secondary/20 flex items-center justify-center mx-auto mb-4 text-secondary">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="font-bold text-foreground mb-2">Instant Fun Statistics</h3>
        <p class="text-sm text-foreground/60 leading-relaxed">Go beyond just years. Discover mind-blowing facts like exactly how many total seconds, minutes, and hours you've been alive on Earth.</p>
      </Card>

      <Card padding="md" class="bg-white/5 border-white/10 shadow-lg text-center hover:-translate-y-1 transition-transform">
        <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center mx-auto mb-4 text-accent">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="font-bold text-foreground mb-2">Event & Milestone Planning</h3>
        <p class="text-sm text-foreground/60 leading-relaxed">Use the target date feature to calculate exactly how many days remain until a significant birthday, anniversary, or official deadline.</p>
      </Card>
    </div>

    <div>
      <div class="text-center mb-10">
        <h2 class="text-3xl font-heading font-bold text-foreground">Frequently Asked Questions</h2>
        <p class="text-foreground/60 mt-2">Everything you need to know about our comprehensive suite of tools.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {faqs.map(faq => (
          <Card padding="md" class="bg-white/5 border-white/10 hover:bg-white/10 transition-colors shadow-lg">
            <h3 class="font-semibold text-lg text-primary mb-2">{faq.q}</h3>
            <p class="text-sm text-foreground/80 leading-relaxed">{faq.a}</p>
          </Card>
        ))}
      </div>
    </div>
  </div>

  <RelatedCalculators current="/" />
  
  <!-- Inject FAQ Schema into the page -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
