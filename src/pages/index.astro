---
import Layout from '../layouts/Layout.astro';
import CalculatorForm from '../components/CalculatorForm.astro';
import ResultCard from '../components/ResultCard.astro';
import Card from '../components/Card.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Age Calculator",
  "url": "https://example.com",
  "description": "Calculate your exact age in years, months, days, hours, and seconds.",
  "applicationCategory": "CalculatorApplication",
  "operatingSystem": "All"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an Age Calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An Age Calculator is an online tool that helps you determine your exact age in years, months, and days from your date of birth to the current date or a specific target date."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate my exact age?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Simply enter your date of birth into the calculator above. The tool automatically computes the time elapsed from that date to today, accounting for leap years and varying month lengths, to give you your exact age."
      }
    },
    {
      "@type": "Question",
      "name": "How does a leap year affect my age calculation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our algorithm precisely calculates the number of days in each month and year, including February 29th during leap years. This ensures that the total number of days lived is 100% accurate."
      }
    }
  ]
};
---

<Layout title="Age Calculator | Find Your Exact Age" description="Accurately calculate your exact age down to the second. Discover fun statistics like total days lived, hours, and next birthday countdown." schema={seoSchema}>
  
  <div class="relative py-16 md:py-24 overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-[128px]"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-secondary/20 rounded-full blur-[128px]"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10 max-w-4xl">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-6xl font-heading font-bold mb-6 tracking-tight">
          Exact Age <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Calculator</span>
        </h1>
        <p class="text-lg md:text-xl text-foreground/80 max-w-2xl mx-auto">
          Calculate your precise age in years, months, weeks, days, hours, and seconds. Enter your birth date below to get started.
        </p>
      </div>

      <Card padding="lg" class="max-w-2xl mx-auto shadow-2xl border-white/20 relative overflow-hidden">
        <!-- Subtle inner glow -->
        <div class="absolute inset-0 bg-gradient-to-b from-white/5 to-transparent pointer-events-none"></div>
        <div class="relative z-10">
          <CalculatorForm />
        </div>
      </Card>

      <ResultCard />
    </div>
  </div>

  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <article class="prose prose-invert prose-lg max-w-none prose-headings:font-heading prose-a:text-primary hover:prose-a:text-primary/80">
      <h2>Welcome to the Ultimate Age Calculator</h2>
      <p>
        Have you ever wondered exactly how old you are down to the very second? Or perhaps you need to calculate the exact age of an individual for legal, medical, or academic purposes? Our <strong>Age Calculator</strong> is designed to provide you with the most precise chronological age calculation possible.
      </p>

      <h3>How Our Age Calculator Works</h3>
      <p>
        Calculating age seems simple on the surface: just subtract your birth year from the current year. However, finding your exact age in months, days, and seconds requires complex calendar math. The Gregorian calendar features varying month lengths (28, 29, 30, and 31 days) and introduces a leap year every four years. 
      </p>
      <p>
        Our tool handles all of these complexities automatically. When you input your Date of Birth (DOB) and select a Target Date, the application computes the exact duration between the two timestamps.
      </p>

      <h3>Benefits of Using an Exact Age Calculator</h3>
      <ul>
        <li><strong>Accuracy:</strong> Perfect for filling out official documents that require age in a specific format (e.g., years and months).</li>
        <li><strong>Fun Statistics:</strong> Discover mind-blowing facts like how many total seconds you've been alive, or how many Earth orbits you've completed.</li>
        <li><strong>Event Planning:</strong> Calculate exactly how many days remain until a significant milestone, like an 18th, 21st, or 50th birthday.</li>
      </ul>

      <h3>Frequently Asked Questions</h3>
      <dl class="mt-8 space-y-6">
        <div>
          <dt class="font-semibold text-xl text-foreground">What is an Age Calculator?</dt>
          <dd class="mt-2 text-foreground/80">An Age Calculator is an online tool that helps you determine your exact age in years, months, and days from your date of birth to the current date or a specific target date.</dd>
        </div>
        <div>
          <dt class="font-semibold text-xl text-foreground">How do I calculate my exact age?</dt>
          <dd class="mt-2 text-foreground/80">Simply enter your date of birth into the calculator above. The tool automatically computes the time elapsed from that date to today, accounting for leap years and varying month lengths, to give you your exact age.</dd>
        </div>
        <div>
          <dt class="font-semibold text-xl text-foreground">How does a leap year affect my age calculation?</dt>
          <dd class="mt-2 text-foreground/80">Our algorithm precisely calculates the number of days in each month and year, including February 29th during leap years. This ensures that the total number of days lived is 100% accurate.</dd>
        </div>
        <div>
          <dt class="font-semibold text-xl text-foreground">Can I calculate my age at a future or past date?</dt>
          <dd class="mt-2 text-foreground/80">Yes! By default, the calculator uses today's date. However, you can change the "Target Date" field to any date in the past or future to find out how old you were, or will be, on that specific day.</dd>
        </div>
      </dl>
    </article>
  </div>

  <RelatedCalculators current="/" />

  <!-- Inject FAQ Schema into the page -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
