---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { SITE_TITLE } from '../lib/constants';
---

<Layout title={`Internal Server Error | ${SITE_TITLE}`} description="Something went wrong on our end. Please try again later or contact support if the issue persists.">
  <div class="container mx-auto px-4 py-20 flex flex-col items-center justify-center min-h-[70vh] text-center">
    <div class="relative mb-8">
      <div class="absolute inset-0 bg-secondary/20 rounded-full blur-[80px] w-64 h-64 -translate-x-1/2 -translate-y-1/2 left-1/2 top-1/2" aria-hidden="true"></div>
      <span class="text-8xl md:text-9xl font-heading font-black text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary tracking-tighter select-none relative">500</span>
    </div>

    <h1 class="font-heading text-2xl md:text-4xl font-bold text-foreground mb-4 max-w-lg relative">
      Internal Server Error
    </h1>
    <p class="text-foreground/70 text-sm md:text-base mb-10 max-w-md relative">
      We encountered an unexpected error. Please try refreshing the page or navigating back home.
    </p>

    <div class="flex flex-wrap gap-4 justify-center items-center relative">
      <Button href="/" size="lg">Go Back Home</Button>
      <Button href="/contact" variant="outline" size="lg">Contact Support</Button>
    </div>
  </div>
</Layout>
