---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Chinese Zodiac Sign Calculator",
  "url": "https://example.com/chinese-zodiac",
  "description": "Calculate your Chinese Zodiac animal based on your birth year.",
  "applicationCategory": "CalculatorApplication"
};
---

<Layout title="Chinese Zodiac Calculator | Find Your Animal Sign" description="Discover your Chinese Zodiac animal. Enter your birth year to find out if you are a Dragon, Tiger, Rat, or another sign in Chinese astrology." schema={seoSchema}>
  
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">
        Chinese Zodiac <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Calculator</span>
      </h1>
      <p class="text-lg text-foreground/80 max-w-2xl mx-auto">
        Discover your Chinese Zodiac animal based on your birth year.
      </p>
    </div>

    <Card padding="lg" class="max-w-xl mx-auto shadow-2xl border-white/20 relative overflow-hidden mb-16">
      <form id="czodiac-form" class="space-y-6 relative z-10">
        <div class="space-y-2">
          <label for="year" class="block text-sm font-medium text-foreground/80">Birth Year</label>
          <input 
            type="number" 
            id="year" 
            min="1900"
            max="2100"
            required 
            class="w-full h-11 px-4 rounded-xl bg-white/5 border border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
          />
        </div>
        <Button type="submit" size="lg" class="w-full">Find My Animal Sign</Button>
      </form>
    </Card>

    <div id="czodiac-results" class="hidden animate-in fade-in slide-in-from-bottom-4 duration-700">
      <Card padding="lg" class="text-center bg-gradient-to-b from-red-900/40 to-black border-red-500/30 max-w-xl mx-auto">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-red-200/80 mb-1">Your Chinese Zodiac Animal Is</h2>
        <div id="cz-sign" class="text-5xl md:text-7xl font-heading font-bold text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-yellow-500 mt-4">Dragon</div>
      </Card>
    </div>
  </div>
</Layout>

<script>
  import { getChineseZodiac } from '../lib/funCalculators';

  const form = document.getElementById('czodiac-form');
  const yearInput = document.getElementById('year') as HTMLInputElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const year = parseInt(yearInput.value);
    
    if (isNaN(year)) {
      alert("Please enter a valid year.");
      return;
    }

    const result = getChineseZodiac(year);
    
    document.getElementById('czodiac-results')?.classList.remove('hidden');
    const signEl = document.getElementById('cz-sign');
    if (signEl) signEl.textContent = result;
  });
</script>
