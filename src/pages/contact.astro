---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
import { SITE_TITLE, SITE_URL, CONTACT_EMAIL } from '../lib/constants';

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": `Contact ${SITE_TITLE}`,
  "description": `Contact ${SITE_TITLE} — send us feedback, questions, or suggestions about our free age, date, and time calculators.`,
  "url": `${SITE_URL}/contact`
};
---

<Layout title={`Contact Us | ${SITE_TITLE}`} description={`Contact ${SITE_TITLE} — send us feedback, questions, or suggestions about our free age, date, and time calculators.`} schema={contactSchema}>
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">Contact Us</h1>
    <p class="text-foreground/70 text-base md:text-lg mb-12 max-w-2xl">
      Have questions, feedback, or suggestions? We would love to hear from you.
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Info Column -->
      <div class="lg:col-span-5 space-y-6">
        <Card padding="lg">
          <h2 class="font-heading text-lg font-bold text-foreground mb-3">Website Purpose</h2>
          <p class="text-sm text-foreground/70 leading-relaxed">
            <strong class="text-foreground">{SITE_TITLE}</strong> is a free, interactive suite of age, date, and time calculators. We help you find exact answers to everyday date math without spreadsheets or guesswork.
          </p>
        </Card>

        <Card padding="lg" class="space-y-4">
          <h2 class="font-heading text-lg font-bold text-foreground mb-1">Get in Touch</h2>
          <div class="space-y-3 text-sm text-foreground/70">
            <div class="flex items-start gap-3">
              <span class="shrink-0">✉️</span>
              <div>
                <p class="font-semibold text-foreground">Support Email</p>
                <a href={`mailto:${CONTACT_EMAIL}`} class="text-primary hover:text-primary/80 transition-colors underline">{CONTACT_EMAIL}</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="shrink-0">⏰</span>
              <div>
                <p class="font-semibold text-foreground">Response Time</p>
                <p>We typically reply within 24–48 hours.</p>
              </div>
            </div>
          </div>
        </Card>
      </div>

      <!-- Form Column -->
      <Card padding="lg" class="lg:col-span-7">
        <h2 class="font-heading text-xl font-bold text-foreground mb-6">Send Us a Message</h2>

        <form
          class="space-y-6"
          id="contact-form"
          action={`mailto:${CONTACT_EMAIL}`}
          method="post"
          enctype="text/plain"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="contact-name" class="block text-xs font-semibold text-foreground/60 uppercase tracking-wider mb-2">Your Name</label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                class="w-full h-11 px-4 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                placeholder="Jane Doe"
              />
            </div>
            <div>
              <label for="contact-email" class="block text-xs font-semibold text-foreground/60 uppercase tracking-wider mb-2">Email Address</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                class="w-full h-11 px-4 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                placeholder="jane@example.com"
              />
            </div>
          </div>

          <div>
            <label for="contact-subject" class="block text-xs font-semibold text-foreground/60 uppercase tracking-wider mb-2">Purpose of Inquiry</label>
            <select
              id="contact-subject"
              name="subject"
              required
              class="w-full h-11 px-4 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary transition-colors"
            >
              <option value="" disabled selected>Select an option...</option>
              <option value="General Feedback">General Feedback & Suggestions</option>
              <option value="Bug Report">Technical Issue / Bug Report</option>
              <option value="Calculation Question">Calculation Accuracy Question</option>
              <option value="Business Partnership">Advertising & Partnerships</option>
              <option value="Copyright/DMCA">Copyright / DMCA Concerns</option>
              <option value="Other">Other Inquiry</option>
            </select>
          </div>

          <div>
            <label for="contact-message" class="block text-xs font-semibold text-foreground/60 uppercase tracking-wider mb-2">Message</label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="6"
              class="w-full px-4 py-3 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary transition-colors resize-y"
              placeholder="How can we help you today?"
            ></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input type="checkbox" id="contact-consent" name="consent" required class="mt-1 accent-primary" />
            <label for="contact-consent" class="text-xs text-foreground/60 leading-snug">
              I agree to the <a href="/privacy-policy" class="underline text-primary hover:text-primary/80">Privacy Policy</a> and consent to having my submitted information used to resolve this inquiry.
            </label>
          </div>

          <Button type="submit" size="lg" class="w-full">Send Message</Button>
        </form>
      </Card>
    </div>
  </div>
</Layout>
