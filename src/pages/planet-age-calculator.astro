---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Planet Age Calculator",
  "url": "https://example.com/planet-age-calculator",
  "description": "Calculate how old you would be on Mars, Jupiter, Venus, and other planets in the solar system.",
  "applicationCategory": "CalculatorApplication"
};
---

<Layout title="Planet Age Calculator | How Old Are You on Mars?" description="Find out exactly how old you would be if you lived on Mars, Venus, Jupiter, or Pluto. A fun space calculator for astronomy lovers." schema={seoSchema}>
  
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">
        Planet Age <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Calculator</span>
      </h1>
      <p class="text-lg text-foreground/80 max-w-2xl mx-auto">
        Discover your exact age on every planet in the solar system.
      </p>
    </div>

    <Card padding="lg" class="max-w-xl mx-auto shadow-2xl border-white/20 relative overflow-hidden mb-16">
      <form id="planet-form" class="space-y-6 relative z-10">
        <div class="space-y-2">
          <label for="dob" class="block text-sm font-medium text-foreground/80">Date of Birth</label>
          <input 
            type="date" 
            id="dob" 
            required 
            class="w-full h-11 px-4 rounded-xl bg-white/5 border border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
          />
        </div>
        <Button type="submit" size="lg" class="w-full">Calculate Planet Ages</Button>
      </form>
    </Card>

    <div id="planet-results" class="hidden animate-in fade-in slide-in-from-bottom-4 duration-700">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4" id="planet-grid">
        <!-- Injected via JS -->
      </div>
    </div>

    
  </div>
</Layout>

<script>
  import { calculatePlanetAges, ORBITAL_PERIODS_IN_EARTH_DAYS } from '../lib/funCalculators';

  const form = document.getElementById('planet-form');
  const dobInput = document.getElementById('dob') as HTMLInputElement;

  const planetColors: Record<string, string> = {
    Mercury: 'bg-gray-500/20 text-gray-300 border-gray-500/30',
    Venus: 'bg-orange-500/20 text-orange-300 border-orange-500/30',
    Earth: 'bg-blue-500/20 text-blue-300 border-blue-500/30',
    Mars: 'bg-red-500/20 text-red-300 border-red-500/30',
    Jupiter: 'bg-amber-700/20 text-amber-300 border-amber-700/30',
    Saturn: 'bg-yellow-600/20 text-yellow-300 border-yellow-600/30',
    Uranus: 'bg-cyan-500/20 text-cyan-300 border-cyan-500/30',
    Neptune: 'bg-blue-700/20 text-blue-400 border-blue-700/30',
    Pluto: 'bg-slate-500/20 text-slate-300 border-slate-500/30',
  };

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const dob = new Date(dobInput.value);
    
    if (isNaN(dob.getTime())) {
      alert("Please enter a valid date.");
      return;
    }

    const ages = calculatePlanetAges(dob);
    
    document.getElementById('planet-results')?.classList.remove('hidden');
    const grid = document.getElementById('planet-grid');
    if (grid) {
      grid.innerHTML = '';
      for (const [planet, age] of Object.entries(ages)) {
        const colorClass = planetColors[planet] || 'bg-white/10 border-white/20 text-foreground';
        grid.innerHTML += `
          <div class="p-4 rounded-2xl border ${colorClass} text-center shadow-lg backdrop-blur-sm">
            <h3 class="text-sm font-semibold uppercase tracking-wider mb-2 opacity-80">${planet}</h3>
            <div class="text-3xl font-mono font-bold">${age}</div>
            <div class="text-xs opacity-60 mt-1">Years Old</div>
          </div>
        `;
      }
    }
  });
</script>
