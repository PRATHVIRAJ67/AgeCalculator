---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Live Birthday Countdown",
  "url": "https://example.com/birthday-countdown",
  "description": "Watch a live, ticking countdown to your next birthday in days, hours, minutes, and seconds.",
  "applicationCategory": "CalculatorApplication"
};
---

<Layout title="Live Birthday Countdown Timer | Track Your Next Birthday" description="Start a live, ticking countdown timer to your next birthday. Watch exactly how many days, hours, minutes, and seconds are left until you celebrate." schema={seoSchema}>
  
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">
        Birthday <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Countdown</span>
      </h1>
      <p class="text-lg text-foreground/80 max-w-2xl mx-auto">
        Start a live ticking clock counting down to your special day.
      </p>
    </div>

    <Card padding="lg" class="max-w-xl mx-auto shadow-2xl border-black/15 dark:border-white/20 relative overflow-hidden mb-12">
      <form id="countdown-form" class="space-y-6 relative z-10">
        <div class="space-y-2">
          <label for="bday" class="block text-sm font-medium text-foreground/80">Date of Birth</label>
          <input 
            type="date" 
            id="bday" 
            required 
            class="w-full h-11 px-4 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
          />
        </div>
        <Button type="submit" size="lg" class="w-full">Start Countdown Clock</Button>
      </form>
    </Card>

    <div id="countdown-display" class="hidden animate-in fade-in zoom-in-95 duration-700">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-semibold text-foreground/80">Time until you turn <span id="turn-age" class="text-primary font-bold">...</span></h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 max-w-3xl mx-auto">
        <Card padding="lg" class="text-center bg-black/4 dark:bg-white/5 border-black/10 dark:border-white/10 relative overflow-hidden group">
          <div class="absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div id="cd-days" class="text-5xl md:text-6xl font-mono font-bold text-foreground tabular-nums mb-2">0</div>
          <div class="text-sm font-medium text-foreground/60 uppercase tracking-widest">Days</div>
        </Card>
        <Card padding="lg" class="text-center bg-black/4 dark:bg-white/5 border-black/10 dark:border-white/10 relative overflow-hidden group">
          <div class="absolute inset-0 bg-secondary/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div id="cd-hours" class="text-5xl md:text-6xl font-mono font-bold text-foreground tabular-nums mb-2">0</div>
          <div class="text-sm font-medium text-foreground/60 uppercase tracking-widest">Hours</div>
        </Card>
        <Card padding="lg" class="text-center bg-black/4 dark:bg-white/5 border-black/10 dark:border-white/10 relative overflow-hidden group">
          <div class="absolute inset-0 bg-accent/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div id="cd-minutes" class="text-5xl md:text-6xl font-mono font-bold text-foreground tabular-nums mb-2">0</div>
          <div class="text-sm font-medium text-foreground/60 uppercase tracking-widest">Minutes</div>
        </Card>
        <Card padding="lg" class="text-center bg-black/4 dark:bg-white/5 border-black/10 dark:border-white/10 relative overflow-hidden group">
          <div class="absolute inset-0 bg-pink-500/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div id="cd-seconds" class="text-5xl md:text-6xl font-mono font-bold text-primary tabular-nums mb-2 drop-shadow-[0_0_8px_rgba(59,130,246,0.5)]">0</div>
          <div class="text-sm font-medium text-foreground/60 uppercase tracking-widest">Seconds</div>
        </Card>
      </div>
      
      <div id="happy-birthday-msg" class="hidden mt-12 text-center animate-bounce">
        <div class="text-6xl md:text-8xl mb-4">🎉🎂🎈</div>
        <h2 class="text-4xl md:text-6xl font-heading font-bold text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-accent">HAPPY BIRTHDAY!</h2>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { calculateBirthdayInfo } from '../lib/birthday';

  const form = document.getElementById('countdown-form');
  const bdayInput = document.getElementById('bday') as HTMLInputElement;
  
  let timerInterval: number | undefined;

  function updateCountdown(targetDate: Date) {
    const now = new Date().getTime();
    const distance = targetDate.getTime() - now;

    if (distance <= 0) {
      clearInterval(timerInterval);
      document.getElementById('happy-birthday-msg')?.classList.remove('hidden');
      return;
    }

    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

    const dEl = document.getElementById('cd-days');
    const hEl = document.getElementById('cd-hours');
    const mEl = document.getElementById('cd-minutes');
    const sEl = document.getElementById('cd-seconds');

    if (dEl) dEl.textContent = days.toString().padStart(2, '0');
    if (hEl) hEl.textContent = hours.toString().padStart(2, '0');
    if (mEl) mEl.textContent = minutes.toString().padStart(2, '0');
    if (sEl) sEl.textContent = seconds.toString().padStart(2, '0');
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const bday = new Date(bdayInput.value);
    
    if (isNaN(bday.getTime())) return;

    if (timerInterval) clearInterval(timerInterval);

    const info = calculateBirthdayInfo(bday);
    const targetDate = info.nextDate;

    document.getElementById('countdown-display')?.classList.remove('hidden');
    document.getElementById('happy-birthday-msg')?.classList.add('hidden');
    
    const turnAgeEl = document.getElementById('turn-age');
    if (turnAgeEl) turnAgeEl.textContent = info.turningAge.toString();

    // Initial call
    updateCountdown(targetDate);

    // Set interval
    timerInterval = window.setInterval(() => {
      updateCountdown(targetDate);
    }, 1000);
  });
</script>
