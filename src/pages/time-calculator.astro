---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Time Calculator",
  "url": "https://example.com/time-calculator",
  "description": "Add or subtract hours, minutes, and seconds easily with our Time Calculator.",
  "applicationCategory": "CalculatorApplication"
};
---

<Layout title="Time Calculator | Add & Subtract Hours, Minutes, Seconds" description="Easily add or subtract time. Perfect for payroll, flight durations, or calculating the exact length of a playlist." schema={seoSchema}>
  
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">
        Time <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Calculator</span>
      </h1>
      <p class="text-lg text-foreground/80 max-w-2xl mx-auto">
        Add or subtract hours, minutes, and seconds with perfect precision.
      </p>
    </div>

    <Card padding="lg" class="max-w-xl mx-auto shadow-2xl border-white/20 relative overflow-hidden mb-16">
      <form id="time-form" class="space-y-8 relative z-10">
        
        <!-- Time 1 -->
        <div>
          <h3 class="text-sm font-semibold text-foreground mb-3 uppercase tracking-wider">Time 1</h3>
          <div class="grid grid-cols-3 gap-4">
            <div>
              <label class="block text-xs text-foreground/60 mb-1">Hours</label>
              <input type="number" id="h1" min="0" value="0" class="w-full h-11 px-3 rounded-xl bg-white/5 border border-white/10 text-center" />
            </div>
            <div>
              <label class="block text-xs text-foreground/60 mb-1">Minutes</label>
              <input type="number" id="m1" min="0" max="59" value="0" class="w-full h-11 px-3 rounded-xl bg-white/5 border border-white/10 text-center" />
            </div>
            <div>
              <label class="block text-xs text-foreground/60 mb-1">Seconds</label>
              <input type="number" id="s1" min="0" max="59" value="0" class="w-full h-11 px-3 rounded-xl bg-white/5 border border-white/10 text-center" />
            </div>
          </div>
        </div>

        <!-- Operation -->
        <div class="flex justify-center">
          <select id="operation" class="h-11 px-6 rounded-xl bg-white/10 border border-white/20 text-foreground font-bold focus:outline-none focus:ring-2 focus:ring-primary">
            <option value="add" class="text-black">Add (+)</option>
            <option value="subtract" class="text-black">Subtract (-)</option>
          </select>
        </div>

        <!-- Time 2 -->
        <div>
          <h3 class="text-sm font-semibold text-foreground mb-3 uppercase tracking-wider">Time 2</h3>
          <div class="grid grid-cols-3 gap-4">
            <div>
              <label class="block text-xs text-foreground/60 mb-1">Hours</label>
              <input type="number" id="h2" min="0" value="0" class="w-full h-11 px-3 rounded-xl bg-white/5 border border-white/10 text-center" />
            </div>
            <div>
              <label class="block text-xs text-foreground/60 mb-1">Minutes</label>
              <input type="number" id="m2" min="0" max="59" value="0" class="w-full h-11 px-3 rounded-xl bg-white/5 border border-white/10 text-center" />
            </div>
            <div>
              <label class="block text-xs text-foreground/60 mb-1">Seconds</label>
              <input type="number" id="s2" min="0" max="59" value="0" class="w-full h-11 px-3 rounded-xl bg-white/5 border border-white/10 text-center" />
            </div>
          </div>
        </div>

        <Button type="submit" size="lg" class="w-full">Calculate Result</Button>
      </form>
    </Card>

    <div id="time-results" class="hidden animate-in fade-in slide-in-from-bottom-4 duration-700">
      <Card padding="lg" class="text-center bg-primary/10 border-primary/20 max-w-xl mx-auto">
        <h2 class="text-xl font-medium text-foreground/80 mb-2">Total Result</h2>
        <div id="res-formatted" class="text-4xl md:text-5xl font-mono font-bold text-primary">0 hr 0 min 0 sec</div>
      </Card>
    </div>

    <article class="prose prose-invert prose-lg max-w-none mt-20 prose-headings:font-heading prose-a:text-primary">
      <h2>How the Time Calculator Works</h2>
      <p>
        Adding or subtracting time manually can be a massive headache because time is calculated in base-60, not base-10. This means you can't just stack numbers and carry the one like standard math; 60 seconds makes a minute, and 60 minutes makes an hour.
      </p>
      <p>
        Our <strong>Time Calculator</strong> converts all of your inputs into raw seconds to perform flawless arithmetic, and then seamlessly translates the result back into an easy-to-read Hour, Minute, and Second format.
      </p>
      <h3>Use Cases:</h3>
      <ul>
        <li><strong>Timesheets & Payroll:</strong> Easily sum up the hours you worked across the week.</li>
        <li><strong>Media Production:</strong> Calculate the total runtime of a video or podcast.</li>
        <li><strong>Aviation & Travel:</strong> Add flight durations and layover times to find total transit length.</li>
      </ul>
    </article>
  </div>
</Layout>

<script>
  import { addTime, subtractTime } from '../lib/timeCalculator';

  const form = document.getElementById('time-form');
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const h1 = parseInt((document.getElementById('h1') as HTMLInputElement).value) || 0;
    const m1 = parseInt((document.getElementById('m1') as HTMLInputElement).value) || 0;
    const s1 = parseInt((document.getElementById('s1') as HTMLInputElement).value) || 0;
    
    const h2 = parseInt((document.getElementById('h2') as HTMLInputElement).value) || 0;
    const m2 = parseInt((document.getElementById('m2') as HTMLInputElement).value) || 0;
    const s2 = parseInt((document.getElementById('s2') as HTMLInputElement).value) || 0;

    const op = (document.getElementById('operation') as HTMLSelectElement).value;

    let result;
    if (op === 'add') {
      result = addTime(h1, m1, s1, h2, m2, s2);
    } else {
      result = subtractTime(h1, m1, s1, h2, m2, s2);
    }

    document.getElementById('time-results')?.classList.remove('hidden');
    const resEl = document.getElementById('res-formatted');
    if (resEl) resEl.textContent = result.formatted;
  });
</script>
