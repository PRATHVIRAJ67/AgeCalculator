---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Time Calculator",
  "url": "https://example.com/time-calculator",
  "description": "Add or subtract days, hours, minutes, and seconds easily with our Time Calculator.",
  "applicationCategory": "CalculatorApplication"
};
---

<Layout title="Time Calculator | Add & Subtract Days, Hours, Minutes, Seconds" description="Easily add or subtract time in days, hours, minutes, and seconds. Perfect for payroll, flight durations, or calculating the exact length of a playlist." schema={seoSchema}>

  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">
        Time <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Calculator</span>
      </h1>
      <p class="text-lg text-foreground/80 max-w-2xl mx-auto">
        Add or subtract two time values in days, hours, minutes, and seconds with perfect precision.
      </p>
    </div>

    <Card padding="lg" class="max-w-xl mx-auto shadow-2xl border-black/15 dark:border-white/20 relative overflow-hidden mb-12">
      <form id="time-form" class="space-y-8 relative z-10">

        <!-- Time 1 -->
        <div>
          <h3 class="text-sm font-semibold text-foreground mb-3 uppercase tracking-wider">Time 1</h3>
          <div class="grid grid-cols-4 gap-2 sm:gap-3">
            <div>
              <label for="d1" class="block text-xs text-foreground/60 mb-1">Days</label>
              <input type="number" id="d1" min="0" value="0" class="w-full h-11 px-2 sm:px-3 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-center" />
            </div>
            <div>
              <label for="h1" class="block text-xs text-foreground/60 mb-1">Hours</label>
              <input type="number" id="h1" min="0" value="0" class="w-full h-11 px-2 sm:px-3 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-center" />
            </div>
            <div>
              <label for="m1" class="block text-xs text-foreground/60 mb-1">Minutes</label>
              <input type="number" id="m1" min="0" value="0" class="w-full h-11 px-2 sm:px-3 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-center" />
            </div>
            <div>
              <label for="s1" class="block text-xs text-foreground/60 mb-1">Seconds</label>
              <input type="number" id="s1" min="0" value="0" class="w-full h-11 px-2 sm:px-3 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-center" />
            </div>
          </div>
        </div>

        <!-- Operation -->
        <div class="flex justify-center">
          <select id="operation" class="h-11 px-6 rounded-xl bg-black/5 dark:bg-white/10 border border-black/15 dark:border-white/20 text-foreground font-bold focus:outline-none focus:ring-2 focus:ring-primary">
            <option value="add">Add (+)</option>
            <option value="subtract">Subtract (−)</option>
          </select>
        </div>

        <!-- Time 2 -->
        <div>
          <h3 class="text-sm font-semibold text-foreground mb-3 uppercase tracking-wider">Time 2</h3>
          <div class="grid grid-cols-4 gap-2 sm:gap-3">
            <div>
              <label for="d2" class="block text-xs text-foreground/60 mb-1">Days</label>
              <input type="number" id="d2" min="0" value="0" class="w-full h-11 px-2 sm:px-3 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-center" />
            </div>
            <div>
              <label for="h2" class="block text-xs text-foreground/60 mb-1">Hours</label>
              <input type="number" id="h2" min="0" value="0" class="w-full h-11 px-2 sm:px-3 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-center" />
            </div>
            <div>
              <label for="m2" class="block text-xs text-foreground/60 mb-1">Minutes</label>
              <input type="number" id="m2" min="0" value="0" class="w-full h-11 px-2 sm:px-3 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-center" />
            </div>
            <div>
              <label for="s2" class="block text-xs text-foreground/60 mb-1">Seconds</label>
              <input type="number" id="s2" min="0" value="0" class="w-full h-11 px-2 sm:px-3 rounded-xl bg-black/4 dark:bg-white/5 border border-black/10 dark:border-white/10 text-center" />
            </div>
          </div>
        </div>

        <Button type="submit" size="lg" class="w-full">Calculate Result</Button>
      </form>
    </Card>

    <div id="time-results" class="hidden max-w-xl mx-auto space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-700">
      <Card padding="lg" class="text-center bg-primary/10 border-primary/20">
        <h2 class="text-xl font-medium text-foreground/80 mb-2">Result</h2>
        <div id="res-formatted" class="text-3xl md:text-4xl font-mono font-bold text-primary">0 seconds</div>
      </Card>

      <Card padding="lg">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground/50 mb-4">Which is equal to</h3>
        <ul class="divide-y divide-black/10 dark:divide-white/10 font-mono">
          <li class="flex items-baseline gap-2 py-2.5">
            <span class="text-foreground/40 text-sm w-8 shrink-0">=</span>
            <span class="text-lg font-semibold tabular-nums"><span id="res-dec-days">0</span> days</span>
          </li>
          <li class="flex items-baseline gap-2 py-2.5">
            <span class="text-foreground/40 text-sm w-8 shrink-0">=</span>
            <span class="text-lg font-semibold tabular-nums"><span id="res-dec-hours">0</span> hours</span>
          </li>
          <li class="flex items-baseline gap-2 py-2.5">
            <span class="text-foreground/40 text-sm w-8 shrink-0">=</span>
            <span class="text-lg font-semibold tabular-nums"><span id="res-dec-minutes">0</span> minutes</span>
          </li>
          <li class="flex items-baseline gap-2 py-2.5">
            <span class="text-foreground/40 text-sm w-8 shrink-0">=</span>
            <span class="text-lg font-semibold tabular-nums"><span id="res-total-seconds">0</span> seconds</span>
          </li>
        </ul>
      </Card>
    </div>

    
  </div>

  <RelatedCalculators current="/time-calculator" />
</Layout>

<script>
  import { calculateTime } from '../lib/timeCalculator';

  const form = document.getElementById('time-form');

  const num = (id: string) => parseInt((document.getElementById(id) as HTMLInputElement).value) || 0;

  // Trim trailing zeros from a fixed-decimal string (e.g. "11.124884")
  const fmtDecimal = (n: number, places: number) =>
    parseFloat(n.toFixed(places)).toLocaleString(undefined, { maximumFractionDigits: places });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const op = (document.getElementById('operation') as HTMLSelectElement).value as 'add' | 'subtract';
    const result = calculateTime(
      op,
      { days: num('d1'), hours: num('h1'), minutes: num('m1'), seconds: num('s1') },
      { days: num('d2'), hours: num('h2'), minutes: num('m2'), seconds: num('s2') }
    );

    document.getElementById('time-results')?.classList.remove('hidden');

    const set = (id: string, text: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    };

    set('res-formatted', result.formatted);
    set('res-dec-days', fmtDecimal(result.decimalDays, 6));
    set('res-dec-hours', fmtDecimal(result.decimalHours, 5));
    set('res-dec-minutes', fmtDecimal(result.decimalMinutes, 3));
    set('res-total-seconds', result.totalSeconds.toLocaleString());
  });
</script>
