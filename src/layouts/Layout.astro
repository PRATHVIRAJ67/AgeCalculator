---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
	canonicalUrl?: string;
  schema?: Record<string, any>;
}

const { 
	title, 
	description,
	canonicalUrl,
  schema
} = Astro.props;
---

<!doctype html>
<html lang="en" class="text-foreground bg-background">
	<head>
		<meta charset="UTF-8" />
		<!-- Runs before first paint: applies a previously chosen dark preference. Light is the default for new visitors. -->
		<script is:inline>
			if (localStorage.getItem('color-theme') === 'dark') {
				document.documentElement.classList.add('dark');
			}
		</script>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

    <SEO title={title} description={description} canonicalUrl={canonicalUrl} schema={schema} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700&family=Space+Grotesk:wght@500;600&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen flex flex-col font-sans relative">
    <Header />
		<main class="flex-1">
      <slot />
    </main>
    <Footer />
	</body>
</html>
