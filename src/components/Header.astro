---
import ThemeToggle from "./ThemeToggle.astro";

import { MAIN_CALCULATORS, FUN_CALCULATORS } from "../lib/calculators";
import { SITE_TITLE } from "../lib/constants";

// Primary nav = the three main calculators (single source of truth)
const navLinks = MAIN_CALCULATORS;
// Fun dropdown shows the secondary tools
const funLinks = FUN_CALCULATORS;
---

<header
  class="sticky top-0 z-50 w-full border-b border-black/10 dark:border-white/10 bg-background/80 backdrop-blur-md"
>
  <div class="container mx-auto px-4 h-16 flex items-center justify-between">
    <a
      href="/"
      class="flex items-center gap-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-lg transition-transform hover:scale-105 active:scale-95"
    >
      <div
        class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-white shadow-[0_0_15px_rgba(59,130,246,0.5)]"
      >
        <svg
          class="w-5 h-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
          <circle cx="12" cy="16" r="3.5"></circle>
          <polyline points="12 14.5 12 16 13.5 16"></polyline>
        </svg>
      </div>
      <span
        class="font-heading font-bold text-xl hidden sm:inline-block tracking-tight"
        >{SITE_TITLE}</span
      >
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-6">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-foreground/70 hover:text-foreground dark:hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.3)] transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm"
          >
            {link.label}
          </a>
        ))
      }
      <div class="h-4 w-px bg-black/10 dark:bg-white/20 mx-2"></div>
      <div class="relative group" id="more-tools-dropdown">
        <button
          id="more-tools-btn"
          class="text-sm font-medium text-foreground/70 hover:text-foreground group-hover:text-foreground transition-all flex items-center gap-1 focus:outline-none cursor-pointer"
        >
          More Tools
          <svg
            class="w-4 h-4 opacity-50 transition-transform duration-200 group-[.open]:rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path></svg
          >
        </button>
        <div
          id="more-tools-menu"
          class="absolute right-0 top-full mt-2 w-48 rounded-xl border border-black/10 dark:border-white/10 bg-background/95 backdrop-blur-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible group-[.open]:opacity-100 group-[.open]:visible transition-all duration-200 transform origin-top-right scale-95 group-hover:scale-100 group-[.open]:scale-100"
        >
          <div class="p-2 flex flex-col">
            {
              funLinks.map((link) => (
                <a
                  href={link.href}
                  class="px-4 py-2 text-sm text-foreground/70 hover:text-foreground hover:bg-black/4 hover:dark:bg-white/5 rounded-lg transition-colors"
                >
                  {link.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-4">
      <ThemeToggle />
      <!-- Mobile Menu Toggle Button -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg hover:bg-black/5 hover:dark:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary transition-colors text-foreground/80 hover:text-foreground"
        aria-label="Toggle Menu"
        aria-expanded="false"
      >
        <svg
          id="menu-icon-open"
          class="w-6 h-6 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="menu-icon-close"
          class="w-6 h-6 hidden transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Menu (Hidden by default) -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-x-0 top-[64px] bg-background/95 backdrop-blur-2xl border-b border-black/10 dark:border-white/10 h-[calc(100dvh-64px)] overflow-y-auto transform transition-transform duration-300 ease-in-out translate-x-full shadow-2xl"
  >
    <div class="container mx-auto px-4 py-8 flex flex-col gap-6">
      <div class="flex flex-col gap-2">
        <h3
          class="text-xs font-bold uppercase tracking-widest text-foreground/40 mb-2"
        >
          Core Tools
        </h3>
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-lg font-medium text-foreground/80 hover:text-foreground hover:bg-black/4 hover:dark:bg-white/5 px-4 py-3 rounded-xl transition-colors flex items-center gap-3"
            >
              <div class="w-2 h-2 rounded-full bg-primary" />
              {link.label}
            </a>
          ))
        }
      </div>

      <div class="h-px w-full bg-black/5 dark:bg-white/10"></div>

      <div class="flex flex-col gap-2">
        <h3
          class="text-xs font-bold uppercase tracking-widest text-foreground/40 mb-2"
        >
          More Tools
        </h3>
        {
          funLinks.map((link) => (
            <a
              href={link.href}
              class="text-lg font-medium text-foreground/80 hover:text-foreground hover:bg-black/4 hover:dark:bg-white/5 px-4 py-3 rounded-xl transition-colors flex items-center gap-3"
            >
              <div class="w-2 h-2 rounded-full bg-secondary" />
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile Menu Logic
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");

  btn?.addEventListener("click", () => {
    const isExpanded = btn.getAttribute("aria-expanded") === "true";

    // Toggle state
    btn.setAttribute("aria-expanded", (!isExpanded).toString());

    if (isExpanded) {
      // Close menu
      menu?.classList.add("translate-x-full");
      menu?.classList.remove("translate-x-0");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      document.body.style.overflow = "";
    } else {
      // Open menu
      menu?.classList.remove("translate-x-full");
      menu?.classList.add("translate-x-0");
      iconOpen?.classList.add("hidden");
      iconClose?.classList.remove("hidden");
      document.body.style.overflow = "hidden"; // Prevent scrolling
    }
  });

  // Desktop Dropdown Toggle Logic
  const moreToolsBtn = document.getElementById("more-tools-btn");
  const moreToolsDropdown = document.getElementById("more-tools-dropdown");

  moreToolsBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    moreToolsDropdown?.classList.toggle("open");
  });

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!moreToolsDropdown?.contains(target)) {
      moreToolsDropdown?.classList.remove("open");
    }
  });
</script>
