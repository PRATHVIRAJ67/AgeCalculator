# Global security headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self';

# Block indexing of the free Cloudflare Pages/Workers preview subdomains so
# only the custom domain gets indexed once it's connected.
https://:project.pages.dev/*
  X-Robots-Tag: noindex
https://:version.:project.pages.dev/*
  X-Robots-Tag: noindex

# Cache compiled static assets for 1 year (filenames are content-hashed)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache icons, logos, and OG images for a week (re-generated rarely)
/*.png
  Cache-Control: public, max-age=604800
/*.svg
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800
/site.webmanifest
  Cache-Control: public, max-age=604800

# Once the custom domain is connected, replace "dateagecalculator" below with
# your actual Cloudflare Pages project name to stop the *.pages.dev preview
# domain from being indexed (avoids duplicate-content penalties).
https://dateagecalculator.pages.dev/*
  X-Robots-Tag: noindex
https://*.dateagecalculator.pages.dev/*
  X-Robots-Tag: noindex
